{
  "cli": {
    "version": ">= 3.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EAS_GRADLE_CACHE": "1",
        "EAS_USE_CACHE": "1"
      }
    },
    "production": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EAS_GRADLE_CACHE": "1",
        "EAS_USE_CACHE": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
